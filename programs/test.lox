fun test (a, b, c) {
    var d = a + b + c; while (d < 3) { print 2; }
}

print(test(1, 2, 3));

class Food {
  eat() {
    print "eating :D";
  }
}

class Bacon < Food {
  eat() {
    super.eat();
    {
      var a = 0; while (a < 3) { print "while crunch"; a = a + 1; }
    }
    for(var i = 0; i < 3; i = i + 1){
      print "for crunch";
    }
  }
}

Bacon().eat();